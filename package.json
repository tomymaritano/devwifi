{
  "name": "devwifi",
  "version": "1.0.0",
  "description": "Developer CLI for diagnosing, inspecting, and sharing Wi-Fi information",
  "type": "module",
  "bin": {
    "devwifi": "./dist/index.js"
  },
  "scripts": {
    "build": "npm run build:web && tsc",
    "build:web": "cd web && npm install && npm run build",
    "dev": "tsx src/index.ts",
    "dev:web": "cd web && npm run dev",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wifi",
    "network",
    "cli",
    "diagnostics",
    "developer-tools",
    "qrcode",
    "dns",
    "speedtest"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist",
    "web/dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "clipboardy": "^4.0.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "ora": "^8.1.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
